# Tiny Prints — Environment Variables

# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com and grab these from:
#   Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Management Password ────────────────────────────────────────────────────────
# Protects the dashboard from casual visitors.
# Share this with anyone who needs to manage orders.
VITE_PRINT_QUEUE_PASSWORD=beeps
